# =============================================================================
# CytoReason UI Performance Framework – Environment Configuration
# Copy this file to .env and fill in real values before running any tests.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Target environment
# ---------------------------------------------------------------------------
# Full base URL of the tenant to test (include trailing slash if required)
BASE_URL=https://apps.private.cytoreason.com/platform/customers/pyy/

# HTTP Basic Auth credentials placed in front of the staging environment
# (leave empty if the gateway is not protected by HTTP Basic Auth)
HTTP_BASIC_USER=
HTTP_BASIC_PASS=

# Auth0 application credentials used to log in to the platform
USERNAME=your-test-user@example.com
PASSWORD=your-test-password

# ---------------------------------------------------------------------------
# Browser settings
# ---------------------------------------------------------------------------
# headless=1 is mandatory for load/stress runs; set to 0 only for debugging
HEADLESS=1

# Playwright browser engine: chromium | firefox | webkit
# Use chromium for maximum performance in headless mode
BROWSER=chromium

# Viewport dimensions (pixels)
BROWSER_WIDTH=1366
BROWSER_HEIGHT=768

# ---------------------------------------------------------------------------
# Timeout settings (milliseconds)
# ---------------------------------------------------------------------------
DEFAULT_TIMEOUT_MS=30000
NAVIGATION_TIMEOUT_MS=60000

# ---------------------------------------------------------------------------
# Think-time settings (seconds, used in Locust between_tasks)
# ---------------------------------------------------------------------------
THINK_TIME_MIN_S=1.0
THINK_TIME_MAX_S=3.0

# ---------------------------------------------------------------------------
# Test profile selection
# load   → stable-state load test with step ramp profile
# stress → ramp-to-break stress test
# ---------------------------------------------------------------------------
TEST_PROFILE=load

# ---------------------------------------------------------------------------
# Concurrency targets
# ---------------------------------------------------------------------------
# Peak concurrent users (Locust --users)
PEAK_USERS=100

# ---------------------------------------------------------------------------
# Artifacts
# ---------------------------------------------------------------------------
# Directory for screenshots, traces, and report outputs
ARTIFACTS_DIR=artifacts

# Report output format: json | csv | both
REPORT_FORMAT=both

# Locust distributed run node identifier (set uniquely per worker)
NODE_ID=worker-1

# ---------------------------------------------------------------------------
# Distributed execution (master node address for Locust workers)
# ---------------------------------------------------------------------------
LOCUST_MASTER_HOST=127.0.0.1
LOCUST_MASTER_PORT=5557
